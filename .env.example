APP_ENV=local
APP_NAME=book-qa-library
APP_VERSION=0.1.0
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_DEBUG=false
APP_REQUEST_ID_HEADER=X-Request-ID
APP_API_KEY=
APP_INGEST_MAX_BYTES=52428800
APP_OCR_ENABLED=true
APP_OCR_LANGS=chi_tra+eng
APP_OCR_MIN_TEXT_CHARS=80
APP_OCR_TESSERACT_CMD=
APP_OCR_MAX_PAGES=0
APP_OCR_PAGE_TIMEOUT_SECONDS=0
APP_OCR_TOTAL_TIMEOUT_SECONDS=0
APP_OCR_ISOLATE_WORKER=false
APP_INGEST_HOST_ALLOWLIST_ENABLED=false
APP_INGEST_HOST_ALLOWLIST=
APP_CORS_ALLOW_ORIGINS=http://localhost:3000
APP_DATABASE_URL=sqlite:///./data/app.db
APP_CONFIG_DIR=./configs
APP_MODELS_PROFILE=local
